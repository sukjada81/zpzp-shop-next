generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  slug          String             @unique(map: "uq_dad_tenants_slug") @db.VarChar(64)
  name          String             @db.VarChar(128)
  primaryDomain String?            @unique(map: "uq_dad_tenants_primary_domain") @map("primary_domain") @db.VarChar(255)
  status        String             @default("active") @db.VarChar(32)
  timezone      String             @default("Asia/Seoul") @db.VarChar(64)
  themeJson     String?            @map("theme_json") @db.LongText
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  orders        Order[]
  points        PointsLedger[]
  products      Product[]
  memberships   TenantMembership[]

  @@map("dad_tenants")
}

model User {
  id              BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  email           String?            @unique(map: "uq_dad_users_email") @db.VarChar(255)
  phone           String?            @unique(map: "uq_dad_users_phone") @db.VarChar(50)
  name            String             @db.VarChar(128)
  passwordHash    String?            @map("password_hash") @db.VarChar(255)
  kakaoProviderId String?            @unique(map: "uq_dad_users_kakao") @map("kakao_provider_id") @db.VarChar(64)
  isSuperAdmin    Boolean            @default(false) @map("is_super_admin")
  status          String             @default("active") @db.VarChar(32)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  orders          Order[]
  points          PointsLedger[]
  createdProducts Product[]          @relation("ProductCreatedBy")
  memberships     TenantMembership[]

  @@map("dad_users")
}

model TenantMembership {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId  BigInt   @map("tenant_id") @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  role      String   @default("MEMBER") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId], map: "uq_dad_membership_tenant_user")
  @@index([userId], map: "idx_dad_membership_user")
  @@index([tenantId, role], map: "idx_dad_membership_tenant_role")
  @@map("dad_tenant_memberships")
}

model Product {
  id           BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId     BigInt          @map("tenant_id") @db.UnsignedBigInt
  title        String          @db.VarChar(255)
  description  String?         @db.MediumText
  status       String          @default("draft") @db.VarChar(32)
  thumbnailUrl String?         @map("thumbnail_url") @db.VarChar(1024)
  imagesJson   String?         @map("images_json") @db.LongText
  basePrice    Decimal         @default(0.00) @map("base_price") @db.Decimal(10, 2)
  pickupOnly   Boolean         @default(true) @map("pickup_only")
  minQty       Int?            @map("min_qty") @db.UnsignedInt
  maxQty       Int?            @map("max_qty") @db.UnsignedInt
  saleStartAt  DateTime?       @map("sale_start_at")
  saleEndAt    DateTime?       @map("sale_end_at")
  createdBy    BigInt          @map("created_by") @db.UnsignedBigInt
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  items        OrderItem[]
  options      ProductOption[]
  creator      User            @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, updatedAt], map: "idx_dad_products_tenant_status")
  @@index([createdBy], map: "dad_products_created_by_fkey")
  @@map("dad_products")
}

model ProductOption {
  id        BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  productId BigInt      @map("product_id") @db.UnsignedBigInt
  name      String      @db.VarChar(255)
  sku       String?     @db.VarChar(64)
  price     Decimal     @default(0.00) @db.Decimal(10, 2)
  stockQty  Int?        @map("stock_qty") @db.UnsignedInt
  isActive  Boolean     @default(true) @map("is_active")
  sortOrder Int         @default(0) @map("sort_order")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  items     OrderItem[]
  product   Product     @relation(fields: [productId], references: [id])

  @@unique([productId, name], map: "uq_dad_option_product_name")
  @@map("dad_product_options")
}

model Order {
  id              BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId        BigInt         @map("tenant_id") @db.UnsignedBigInt
  orderNo         String         @unique(map: "uq_dad_orders_order_no") @map("order_no") @db.VarChar(64)
  userId          BigInt?        @map("user_id") @db.UnsignedBigInt
  buyerName       String         @map("buyer_name") @db.VarChar(128)
  buyerPhone      String         @map("buyer_phone") @db.VarChar(50)
  status          String         @default("PENDING") @db.VarChar(32)
  paymentStatus   String         @default("unpaid") @map("payment_status") @db.VarChar(32)
  subtotalAmount  Decimal        @default(0.00) @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount  Decimal        @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  pointUsedAmount Decimal        @default(0.00) @map("point_used_amount") @db.Decimal(12, 2)
  totalAmount     Decimal        @default(0.00) @map("total_amount") @db.Decimal(12, 2)
  pickupAt        DateTime?      @map("pickup_at")
  memo            String?        @db.VarChar(1024)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  items           OrderItem[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])
  payments        Payment[]
  points          PointsLedger[]

  @@index([tenantId], map: "dad_orders_tenant_id_fkey")
  @@index([userId], map: "dad_orders_user_id_fkey")
  @@map("dad_orders")
}

model OrderItem {
  id                 BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  orderId            BigInt         @map("order_id") @db.UnsignedBigInt
  productId          BigInt         @map("product_id") @db.UnsignedBigInt
  optionId           BigInt?        @map("option_id") @db.UnsignedBigInt
  titleSnapshot      String         @map("title_snapshot") @db.VarChar(255)
  optionNameSnapshot String?        @map("option_name_snapshot") @db.VarChar(255)
  unitPriceSnapshot  Decimal        @default(0.00) @map("unit_price_snapshot") @db.Decimal(12, 2)
  qty                Int            @db.UnsignedInt
  lineTotal          Decimal        @default(0.00) @map("line_total") @db.Decimal(12, 2)
  status             String         @default("normal") @db.VarChar(32)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  option             ProductOption? @relation(fields: [optionId], references: [id])
  order              Order          @relation(fields: [orderId], references: [id])
  product            Product        @relation(fields: [productId], references: [id])

  @@index([orderId], map: "idx_items_order")
  @@index([optionId], map: "dad_order_items_option_id_fkey")
  @@index([productId], map: "dad_order_items_product_id_fkey")
  @@map("dad_order_items")
}

model Payment {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  orderId      BigInt    @map("order_id") @db.UnsignedBigInt
  provider     String    @default("none") @db.VarChar(32)
  method       String    @default("none") @db.VarChar(32)
  status       String    @default("initiated") @db.VarChar(32)
  amount       Decimal   @default(0.00) @db.Decimal(12, 2)
  providerTxId String?   @map("provider_tx_id") @db.VarChar(128)
  paidAt       DateTime? @map("paid_at")
  rawJson      String?   @map("raw_json") @db.LongText
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  order        Order     @relation(fields: [orderId], references: [id])

  @@index([orderId], map: "dad_payments_order_id_fkey")
  @@map("dad_payments")
}

model PointsLedger {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tenantId     BigInt   @map("tenant_id") @db.UnsignedBigInt
  userId       BigInt   @map("user_id") @db.UnsignedBigInt
  type         String   @db.VarChar(32)
  amount       Int
  balanceAfter Int?     @map("balance_after")
  reason       String?  @db.VarChar(255)
  orderId      BigInt?  @map("order_id") @db.UnsignedBigInt
  createdAt    DateTime @default(now()) @map("created_at")
  order        Order?   @relation(fields: [orderId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, createdAt], map: "idx_points_tenant_user_created")
  @@index([orderId], map: "dad_points_ledger_order_id_fkey")
  @@index([userId], map: "dad_points_ledger_user_id_fkey")
  @@map("dad_points_ledger")
}
