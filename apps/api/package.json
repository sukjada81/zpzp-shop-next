{
  "name": "@dad/api",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:gen": "prisma generate",
    "prisma:introspect": "prisma db pull",
    "prisma:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:test:push": "dotenv -e .env.test -- node scripts/db-test-push.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "9.4.0",
    "@fastify/multipart": "7.7.3",
    "@fastify/session": "10.9.0",
    "@fastify/static": "7.0.4",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "4.29.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
