{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts",
    "../../../apps/api/prisma/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "test"]
}