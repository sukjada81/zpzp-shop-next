# =============================================================
#  줍줍 shop-next / apps/api (백엔드 / Fastify + Prisma)  —  .env.example
#  사용법:  cp apps/api/.env.example apps/api/.env  후 값 채우기
#  로더: server.ts 의 `import "dotenv/config"` 가 이 파일(apps/api/.env)을 읽음
#  ⚠️ 실제 시크릿·DB 접속정보 커밋 금지. "→ 요청" 항목은 팀에 문의.
# =============================================================

# ---- DB 접속 (Prisma) ----
# 형식: mysql://<user>:<password>@<host>:<port>/<db>
#  - 로컬 DB를 쓰거나(권장) 공유 개발 DB에 연결. 운영 b2bdb 에 직접 붙지 말 것.
#  - 실제 접속 문자열(호스트/계정/비번/DB명)은 → 팀장님 혹은 현승우(본인)에게 요청
DATABASE_URL=                      # → 팀장님 혹은 현승우(본인)에게 요청 (예: mysql://dev:***@127.0.0.1:3306/b2bdb)

# ---- 서버 포트 ----
PORT=4000

# ---- 세션 서명키 (@fastify/session) ----
SESSION_SECRET=                    # → 팀장님 혹은 현승우(본인)에게 요청 (32자 이상 랜덤; 로컬은 임의 랜덤 가능)

# ---- Prisma 사용 스위치 ----
USE_PRISMA=1

# ---- 테넌트 해석 ----
TENANT_BASE_DOMAIN=zpzp.local      # 프론트(.env.local)와 동일하게 맞출 것
TENANT_RESOLVE_MODE=               # (선택) 테넌트 해석 방식 오버라이드

# ---- 상품 이미지 원본(레거시 이미지 경로 프리픽스) ----
GOODS_IMAGE_BASE_URL=              # → 팀장님 혹은 현승우(본인)에게 요청 (상품 이미지 원본 URL)

# ---- (코드에서 참조하는 오리진/쿠키 — 프론트와 동일 세트로 맞출 것) ----
# AUTH_ORIGIN=http://auth.zpzp.local:3000
# APP_ORIGIN=http://zpzp.local:3000
# COOKIE_DOMAIN=.zpzp.local
# NEXT_PUBLIC_AUTH_ORIGIN=http://auth.zpzp.local:3000
