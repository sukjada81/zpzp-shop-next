# =============================================================
#  줍줍 shop-next (프론트엔드 / Next.js)  —  .env.example
#  사용법:  cp .env.example .env.local  후 값 채우기
#  ⚠️ 실제 시크릿은 절대 커밋 금지. "→ 팀장님 혹은 현승우(본인)에게 요청" 항목은 값 요청.
#
#  ★★ 중요: 도메인/오리진 변수는 "한 세트"입니다. host 하나만 바꾸면
#     카카오 redirect_uri 불일치·쿠키 미공유·테넌트 해석 실패가 납니다.
#     아래 값들은 로컬(hosts 파일 + zpzp.local 가짜도메인) 기준 예시입니다.
#     자세한 설명: zpzp-shop-php 리포의 README.md 참고.
# =============================================================

# ---- 로컬 서브도메인 방식 (권장: hosts 파일 + 가짜도메인) ----
# /etc/hosts 또는 C:\Windows\System32\drivers\etc\hosts 에 아래 추가:
#   127.0.0.1  zpzp.local a.zpzp.local seller.zpzp.local auth.zpzp.local select-tenant.zpzp.local
TENANT_BASE_DOMAIN=zpzp.local
TENANT_BY_SUBDOMAIN=1
NEXT_PUBLIC_LOCAL_TENANT_PORT=3000

# 각 역할별 오리진 (전부 같은 :3000, 서브도메인만 다름)
SITE_ORIGIN=http://zpzp.local:3000
AUTH_ORIGIN=http://auth.zpzp.local:3000
SELECT_TENANT_ORIGIN=http://select-tenant.zpzp.local:3000
SELLER_ORIGIN=http://seller.zpzp.local:3000
NEXT_INTERNAL_ORIGIN=http://127.0.0.1:3000

# 쿠키 공유 도메인 — 서브도메인 간 세션 공유에 필수.
#  ⚠️ *.localhost 로는 이 값이 무시되어 세션이 공유되지 않음(코드가 localhost를 host-only로 처리).
#     반드시 위 zpzp.local 같은 가짜도메인을 써야 .zpzp.local 로 쿠키가 공유됨.
COOKIE_DOMAIN=.zpzp.local

# ---- API 연결 (apps/api, :4000) ----
API_BASE_URL=http://127.0.0.1:4000

# ---- 레거시 PHP(shop-php) 연동 경로 ----
# 로컬에 PHP를 안 띄우면 개발/운영 PHP를 가리킴 → 값은 팀에 확인
PHP_API_BASE=                      # → 팀장님 혹은 현승우(본인)에게 요청 (예: http://localhost/legacy_api)

# ---- 상품 이미지 등 정적 자산 오리진 ----
NEXT_PUBLIC_ASSET_ORIGIN=          # → 팀장님 혹은 현승우(본인)에게 요청 (상품 이미지 CDN/원본 URL)

# ---- 인증(카카오/세션) ----
# 로컬에서 카카오 없이 개발하려면 우회 켬(로컬 호스트에서만 동작):
LOCAL_BYPASS_AUTH=1
# 카카오 실제 테스트 시 필요 (아래 3개). LOCAL_BYPASS_AUTH=1 이면 없어도 앱은 뜸.
KAKAO_CLIENT_ID=                   # → 팀장님 혹은 현승우(본인)에게 요청 (카카오 앱 REST API 키)
KAKAO_CLIENT_SECRET=               # → 팀장님 혹은 현승우(본인)에게 요청 (없을 수도 있음: 콘솔에서 Client Secret ON일 때만)
AUTH_STATE_SECRET=                 # → 팀장님 혹은 현승우(본인)에게 요청 (OAuth state HMAC 서명키; 아무 랜덤 문자열이어도 로컬 자체 테스트는 가능)

# ---- (선택) 코드에서 참조하지만 대부분 기본값/자동 주입 ----
# NEXT_PUBLIC_API_BASE_URL=        # 브라우저에서 API 직접 호출 시. 보통 프록시(/api) 사용
# NEXT_PUBLIC_AUTH_ORIGIN=         # 클라이언트에서 AUTH_ORIGIN 필요할 때
# NEXT_PUBLIC_SITE_URL=            # 공개 사이트 URL
# NEXT_PUBLIC_APP_URL=             #
# NEXT_PUBLIC_BASE_URL=            #
# NEXT_PUBLIC_TENANTS=             # 테넌트 목록 하드코딩 주입(로컬 편의)
# MAIN_ORIGIN=                     #
# LOCAL_TENANT_PORT=3000           # NEXT_PUBLIC_LOCAL_TENANT_PORT 의 서버측 별칭
# TENANT_RESOLVE_MODE=             # 테넌트 해석 방식 오버라이드(기본 서브도메인)
# NODE_ENV / VERCEL_URL            # 자동 주입 — 직접 설정하지 말 것

# ---- 참고: MOCK_AUTH 는 현재 코드에서 참조되지 않는 잔재(설정해도 무효) ----
