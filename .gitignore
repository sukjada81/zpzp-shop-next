# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 실제 시크릿은 추적하지 않음(값은 팀에 요청). 템플릿 .env.example 만 커밋.
.env.local
.env.production
apps/api/.env
# 템플릿은 추적 대상으로 유지
!.env.example
!apps/api/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# markdown — 로컬에서만 관리 (git 추적 제외)
*.md
# CLAUDE.md 는 프로젝트 컨텍스트 문서라 예외로 추적
!CLAUDE.md
